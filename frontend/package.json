{
  "name": "laria-field-agent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:http": "VITE_DEV_HTTP=1 vite",
    "tunnel": "cloudflared tunnel --url http://127.0.0.1:5173",
    "tunnel:vite-https": "cloudflared tunnel --no-tls-verify --url https://localhost:5173",
    "tunnel:http": "cloudflared tunnel --url http://127.0.0.1:5173",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0",
    "lucide-react": "^0.468.0",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-alert-dialog": "^1.1.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "vite": "^6.0.0",
    "eslint": "^9.17.0"
  }
}
